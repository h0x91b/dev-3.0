# Keep the build context small — the multi-stage builder only needs the
# source tree, package.json, and bun.lock. Anything below is rebuilt from
# scratch inside the image and just wastes `docker build` bandwidth.

# Dependencies (reinstalled via bun install in the builder stage)
node_modules/
bun.lockb.zst

# Build output (regenerated by vite + bun build in the builder stage)
/dist/
/build/
/artifacts/
/artifacts-*/

# Generated source — scripts regenerate these during the build
src/shared/build-info.generated.ts
src/bun/changelog-bundled.ts
changelog.json

# Editor and tooling state
.git/
.github/
.vscode/
.idea/
*.log
.DS_Store

# Tests and docs don't ship in the runtime binaries, but they're cheap
# enough that excluding them isn't worth the surprise when someone expects
# to run tests inside the image. We only drop clearly-unused stuff.
*.bun-build

# Docker itself shouldn't copy its own build context recursively.
docker/

# Local dev-3.0 overrides
.dev3/config.local.json
.claude/settings.local.json
